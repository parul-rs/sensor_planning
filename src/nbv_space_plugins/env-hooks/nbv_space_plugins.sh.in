# Prepend nbv_space_plugins lib to GZ_SIM_SYSTEM_PLUGIN_PATH
AMENT_CURRENT_PREFIX="@PACKAGE_PREFIX@"
if [ -z "${GZ_SIM_SYSTEM_PLUGIN_PATH}" ]; then
  export GZ_SIM_SYSTEM_PLUGIN_PATH="${AMENT_CURRENT_PREFIX}/lib"
elif ! echo ":${GZ_SIM_SYSTEM_PLUGIN_PATH}:" | grep -q ":${AMENT_CURRENT_PREFIX}/lib:"; then
  export GZ_SIM_SYSTEM_PLUGIN_PATH="${AMENT_CURRENT_PREFIX}/lib:${GZ_SIM_SYSTEM_PLUGIN_PATH}"
fi