<?xml version="1.0"?>
<robot name="satellite" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="scale" value="1.5"/>
  <xacro:property name="mesh_scale" value="${0.02 * scale} ${0.02 * scale} ${0.02 * scale}"/>

  <link name="body_link_1">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin xyz="${-4.25 * scale} ${-4.6 * scale} ${-1.945 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Body1_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${-4.25 * scale} ${-4.6 * scale} ${-1.945 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Body1_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="body_link_1">
    <kinematic>true</kinematic>
  </gazebo>

  <joint name="joint1" type="fixed">
    <parent link="body_link_1"/>
    <child link="body_link_2"/>
    <origin xyz="0 0 ${1.275 * scale}"/>
  </joint>

  <link name="body_link_2">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin xyz="${-3.94 * scale} ${-4.13 * scale} ${-2.095 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Body2_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${-3.94 * scale} ${-4.13 * scale} ${-2.095 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Body2_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_2" type="fixed">
    <parent link="body_link_1"/>
    <child link="panel_link"/>
    <origin xyz="${0.01 * scale} ${-0.02 * scale} ${0.01 * scale}" rpy="0 3.14 0"/>
  </joint>

  <link name="panel_link">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin xyz="${0.01 * scale} 0 ${-1 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Panel_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${0.01 * scale} 0 ${-1 * scale}"/>
      <geometry>
        <mesh filename="model://nbv_space/meshes/SOHO_Panel_20thScale.stl" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================================================================== -->
  <!-- PosePublisher — required for /model/target/pose to actually publish  -->
  <!--                                                                       -->
  <!-- SceneBroadcaster does NOT automatically publish per-model pose       -->
  <!-- topics; that requires this separate plugin. Without it, the bridge's -->
  <!-- ROS-side /model/target/pose endpoint exists but nothing ever         -->
  <!-- publishes to it, so chaser_hcw_dynamics.py's subscription callback   -->
  <!-- never fires.                                                         -->
  <!--                                                                       -->
  <!-- NOTE: publish_model_pose is documented but not actually wired up in  -->
  <!-- the current implementation (see gazebosim/gz-sim#2690) — setting     -->
  <!-- publish_nested_model_pose=true is what's actually required to get    -->
  <!-- the model's own pose published. Both are set here defensively.      -->
  <!-- ==================================================================== -->
  <gazebo>
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_model_pose>true</publish_model_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose>
      <publish_link_pose>false</publish_link_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_sensor_pose>false</publish_sensor_pose>
      <use_pose_vector_msg>false</use_pose_vector_msg>
      <update_frequency>50</update_frequency>
    </plugin>
  </gazebo>

</robot>